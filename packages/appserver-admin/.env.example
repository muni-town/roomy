# ── Appserver Admin Dashboard ──────────────────────────────────────────────
# Copy this file to .env and fill in values.

# Comma-separated DIDs allowed to access the admin dashboard.
# Fails closed: if unset or empty, no one can log in.
# Set at least one DID in development.
PUBLIC_APPSERVER_ADMIN_DIDS=

# DID of the appserver to connect to
VITE_APPSERVER_DID=did:web:api.roomy.space

# Override the WebSocket origin (for local development)
# VITE_APPSERVER_WS_ORIGIN=ws://127.0.0.1:8080
