# Discord bridge configuration
PUBLIC_DISCORD_BRIDGE=http://localhost:3301
PUBLIC_BRIDGE_DID=did:plc:vjztjtisourrydgksg44u7fe

# PDS configuration for account creation / login
PUBLIC_PDS="https://roomy.chat"
PUBLIC_PDS_HANDLE_SUFFIX=".roomy.chat"
PUBLIC_PDS_INVITE_CODE="sort-of-secret"

# Appserver DID (Staging)
VITE_APPSERVER_DID=did:web:api-dev.roomy.space
# Appserver DID (Production)
# VITE_APPSERVER_DID=did:web:api.roomy.space

# Set to "true" in production to use public OAuth client metadata
# instead of the loopback redirect. Requires OAUTH_HOST at build time.
VITE_OAUTH_PUBLIC_CLIENT=false

# Test-mode: app-password credentials for headless E2E testing. When both are
# set, the app auto-logs in via app password (bypassing OAuth) so browser-based
# tests can exercise the full XRPC + sync stack without a public redirect URI.
# Create an app password at https://bsky.social/settings/app-passwords
PUBLIC_TEST_IDENTIFIER=did:plc:your-test-did
PUBLIC_TEST_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
