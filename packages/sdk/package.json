{
  "name": "@roomy-space/sdk",
  "version": "0.3.1",
  "license": "MPL-2.0",
  "type": "module",
  "packageManager": "pnpm@10.10.0",
  "repository": {
    "url": "https://github.com/muni-town/roomy-sdk"
  },
  "files": [
    "./src",
    "./dist",
    "./README.md"
  ],
  "scripts": {
    "dev": "pkgroll --watch",
    "build": "pnpm generate:lexicons && pkgroll",
    "format": "prettier . --write",
    "build-lib": "pnpm build",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run tests/integration",
    "test:unit": "vitest run tests/operations",
    "generate:lexicons": "tsx scripts/generate-lexicons.ts",
    "check:lexicons": "tsx scripts/generate-lexicons.ts --check"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./browser": {
      "development": "./src/browser/index.ts",
      "import": "./dist/browser/index.js",
      "types": "./dist/browser/index.d.ts"
    },
    "./package/operations": {
      "development": "./src/operations/index.ts",
      "import": "./dist/operations/index.js"
    },
    "./package/operations/room": {
      "development": "./src/operations/room.ts",
      "import": "./dist/operations/room.js"
    },
    "./package/operations/message": {
      "development": "./src/operations/message.ts",
      "import": "./dist/operations/message.js"
    },
    "./package/operations/reaction": {
      "development": "./src/operations/reaction.ts",
      "import": "./dist/operations/reaction.js"
    },
    "./svelte": {
      "svelte": "./src/svelte/index.svelte.ts",
      "default": "./src/svelte/index.svelte.ts"
    }
  },
  "peerDependencies": {
    "@tanstack/svelte-query": "^6.0.0",
    "svelte": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "svelte": {
      "optional": true
    },
    "@tanstack/svelte-query": {
      "optional": true
    }
  },
  "devDependencies": {
    "@repo/tsconfig": "workspace:*",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^2.1.8",
    "@vitest/ui": "^2.1.8",
    "beachball": "^2.54.0",
    "dotenv": "^17.2.3",
    "pkgroll": "^2.12.2",
    "prettier": "3.5.3",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.3",
    "turbo": "^2.5.2",
    "typescript": "^5.8.3",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@ark/util": "^0.56.0",
    "@atcute/cbor": "^2.2.8",
    "@atproto/api": "^0.14.22",
    "@atproto/lexicon": "^0.4.14",
    "@atproto/oauth-client": "^0.5.6",
    "@atproto/oauth-client-browser": "^0.3.39",
    "@muni-town/leaf-client": "0.1.0-alpha.17",
    "@opentelemetry/api": "^1.9.0",
    "@tanstack/query-core": "5.100.10",
    "arktype": "^2.1.29",
    "ulidx": "^2.4.1"
  }
}
