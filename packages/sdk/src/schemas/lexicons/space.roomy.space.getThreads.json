          "type": "ref",
          "ref": "#activity"
        },
        "channel": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      }
    },
    "main": {
      "type": "query",
      "parameters": {
        "type": "params",
        "required": [
          "spaceId"
        ],
        "properties": {
          "spaceId": {
            "type": "string"
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": [
            "threads"
          ],
          "properties": {
            "threads": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "#threads"
              }
            }
          }
        }
      }
