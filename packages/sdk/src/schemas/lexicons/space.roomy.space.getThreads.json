{
  "lexicon": 1,
  "id": "space.roomy.space.getThreads",
  "defs": {
    "latestMembers": {
      "type": "object",
      "required": [
        "did"
      ],
      "properties": {
        "avatar": {
          "type": "string"
        },
        "did": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      }
    },
    "activity": {
      "type": "object",
      "required": [
        "latestMembers"
      ],
      "properties": {
        "latestMembers": {
          "type": "array",
          "items": {
            "type": "ref",
            "ref": "#latestMembers"
          }
        },
        "latestTimestamp": {
          "type": "string"
        }
      }
    },
    "threads": {
      "type": "object",
      "required": [
