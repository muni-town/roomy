{
  "lexicon": 1,
  "id": "space.roomy.room.getThreads",
  "defs": {
    "latestMembers": {
      "type": "object",
      "required": [
        "did"
      ],
      "nullable": [
        "avatar",
        "name"
      ],
      "properties": {
        "did": {
          "type": "string"
        },
        "avatar": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      }
    },
    "author": {
      "type": "object",
      "required": [
        "did"
      ],
      "nullable": [
        "avatar",
        "name"
      ],
      "properties": {
        "did": {
          "type": "string"
        },
        "avatar": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      }
    },
    "latestMessage": {
      "type": "object",
      "required": [
        "author",
        "content",
        "id"
      ],
      "properties": {
        "author": {
          "type": "ref",
          "ref": "#author"
        },
        "content": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "timestamp": {
          "type": "string"
        }
      }
    },
    "activity": {
      "type": "object",
      "required": [
        "latestMembers"
      ],
      "properties": {
        "latestMembers": {
          "type": "array",
          "items": {
            "type": "ref",
            "ref": "#latestMembers"
          }
        },
        "latestMessage": {
          "type": "ref",
          "ref": "#latestMessage"
        },
        "latestTimestamp": {
          "type": "string"
        }
      }
    },
    "threads": {
      "type": "object",
      "required": [
        "activity",
        "id"
      ],
      "properties": {
        "activity": {
          "type": "ref",
          "ref": "#activity"
        },
        "id": {
          "type": "string"
        },
        "canonicalParent": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "unreadCount": {
          "type": "integer"
        }
      }
    },
    "main": {
      "type": "query",
      "parameters": {
        "type": "params",
        "required": [
          "roomId"
        ],
        "properties": {
          "roomId": {
            "type": "string"
          },
          "cursor": {
            "type": "string"
          },
          "limit": {
            "type": "string"
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": [
            "threads"
          ],
          "properties": {
            "threads": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "#threads"
              }
            },
            "cursor": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
