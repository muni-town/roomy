{
  "lexicon": 1,
  "id": "space.roomy.room.getThreads",
  "defs": {
    "main": {
      "type": "query",
      "description": "Returns all threads canonically linked from the given channel, filtered by the caller's read access. Caller must have read access to the channel.",
      "parameters": {
        "type": "params",
        "required": ["roomId"],
        "properties": {
          "roomId": { "type": "string" }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["threads"],
          "properties": {
            "threads": {
              "type": "array",
              "items": { "type": "ref", "ref": "#thread" }
            }
          }
        }
      }
    },
    "thread": {
      "type": "object",
      "required": ["id", "name", "canonicalParent", "activity"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "canonicalParent": { "type": "string" },
        "activity": { "type": "ref", "ref": "#activity" }
      }
    },
    "activity": {
      "type": "object",
      "required": ["latestTimestamp", "latestMembers"],
      "properties": {
        "latestTimestamp": { "type": "string", "format": "datetime" },
        "latestMembers": {
          "type": "array",
          "items": { "type": "ref", "ref": "#activityMember" }
        }
      }
    },
    "activityMember": {
      "type": "object",
      "required": ["did", "name", "avatar"],
      "properties": {
        "did": { "type": "string", "format": "did" },
        "name": { "type": "string" },
        "avatar": { "type": "string" }
      }
    }
  }
}
