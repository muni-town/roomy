{
  "lexicon": 1,
  "id": "space.roomy.room.getMessages",
  "defs": {
    "main": {
      "type": "query",
      "description": "Paginated message history for a room. Cursor is a message entity ID (ULID); messages older than the cursor are returned. Caller must have read access to the room.",
      "parameters": {
        "type": "params",
        "required": ["roomId"],
        "properties": {
          "roomId": { "type": "string" },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 50
          },
          "cursor": { "type": "string" }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["messages", "cursor"],
          "properties": {
            "messages": {
              "type": "array",
              "items": { "type": "ref", "ref": "#message" }
            },
            "cursor": { "type": "string" }
          }
        }
      }
    },
    "message": {
      "type": "object",
      "required": [
        "id",
        "content",
        "authorDid",
        "authorName",
        "authorAvatar",
        "timestamp",
        "replyTo",
        "forwardedFrom",
        "reactions",
        "media",
        "tags"
      ],
      "properties": {
        "id": { "type": "string" },
        "content": { "type": "string" },
        "authorDid": { "type": "string", "format": "did" },
        "authorName": { "type": "string" },
        "authorAvatar": { "type": "string" },
        "timestamp": { "type": "string", "format": "datetime" },
        "replyTo": { "type": "string" },
        "forwardedFrom": { "type": "ref", "ref": "#forwardedFrom" },
        "reactions": {
          "type": "array",
          "items": { "type": "ref", "ref": "#reaction" }
        },
        "media": {
          "type": "array",
          "items": { "type": "ref", "ref": "#media" }
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "forwardedFrom": {
      "type": "object",
      "required": ["name", "roomId"],
      "properties": {
        "name": { "type": "string" },
        "roomId": { "type": "string" }
      }
    },
    "reaction": {
      "type": "object",
      "required": ["emoji", "dids"],
      "properties": {
        "emoji": { "type": "string" },
        "dids": {
          "type": "array",
          "items": { "type": "string", "format": "did" }
        }
      }
    },
    "media": {
      "type": "object",
      "required": ["url", "type", "alt"],
      "properties": {
        "url": { "type": "string" },
        "type": { "type": "string" },
        "alt": { "type": "string" }
      }
    }
  }
}
