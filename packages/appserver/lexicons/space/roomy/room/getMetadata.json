{
  "lexicon": 1,
  "id": "space.roomy.room.getMetadata",
  "defs": {
    "main": {
      "type": "query",
      "description": "Returns room metadata + recently active threads (replaces the separate getLinkedRooms query). Caller must have read access to the room. Stage-1: unread fields are 0/null.",
      "parameters": {
        "type": "params",
        "required": ["roomId"],
        "properties": {
          "roomId": { "type": "string" }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "ref",
          "ref": "#metadata"
        }
      }
    },
    "metadata": {
      "type": "object",
      "required": [
        "name",
        "kind",
        "spaceId",
        "defaultAccess",
        "canRead",
        "canWrite",
        "lastRead",
        "unreadCount",
        "recentThreads"
      ],
      "properties": {
        "name": { "type": "string" },
        "kind": {
          "type": "string",
          "description": "Short kind: 'channel', 'thread', 'page', etc."
        },
        "spaceId": { "type": "string" },
        "defaultAccess": {
          "type": "string",
          "knownValues": ["readwrite", "read", "none"]
        },
        "canRead": { "type": "boolean" },
        "canWrite": { "type": "boolean" },
        "lastRead": { "type": "string", "format": "datetime" },
        "unreadCount": { "type": "integer" },
        "recentThreads": {
          "type": "array",
          "items": { "type": "ref", "ref": "#recentThread" }
        }
      }
    },
    "recentThread": {
      "type": "object",
      "required": ["id", "name", "canRead", "canWrite", "unreadCount", "lastRead"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "canRead": { "type": "boolean" },
        "canWrite": { "type": "boolean" },
        "unreadCount": { "type": "integer" },
        "lastRead": { "type": "string", "format": "datetime" }
      }
    }
  }
}
