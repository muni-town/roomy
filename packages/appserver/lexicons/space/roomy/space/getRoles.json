{
  "lexicon": 1,
  "id": "space.roomy.space.getRoles",
  "defs": {
    "main": {
      "type": "query",
      "description": "Returns roles defined in a space with their per-room permissions and assigned member DIDs. Soft-deleted roles are omitted. Caller must be a member or admin of the space.",
      "parameters": {
        "type": "params",
        "required": ["spaceId"],
        "properties": {
          "spaceId": { "type": "string" }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["roles"],
          "properties": {
            "roles": {
              "type": "array",
              "items": { "type": "ref", "ref": "#role" }
            }
          }
        }
      }
    },
    "role": {
      "type": "object",
      "required": ["id", "name", "avatar", "description", "rooms", "memberDids"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "avatar": { "type": "string" },
        "description": { "type": "string" },
        "rooms": {
          "type": "array",
          "items": { "type": "ref", "ref": "#roleRoom" }
        },
        "memberDids": {
          "type": "array",
          "items": { "type": "string", "format": "did" }
        }
      }
    },
    "roleRoom": {
      "type": "object",
      "required": ["roomId", "permission"],
      "properties": {
        "roomId": { "type": "string" },
        "permission": {
          "type": "string",
          "knownValues": ["read", "readwrite"]
        }
      }
    }
  }
}
