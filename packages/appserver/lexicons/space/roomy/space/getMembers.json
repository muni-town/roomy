{
  "lexicon": 1,
  "id": "space.roomy.space.getMembers",
  "defs": {
    "main": {
      "type": "query",
      "description": "Returns the members of a space with profile data, plus admins-without-membership as `externalAdmins` (admin and membership are orthogonal). Caller must be a member or admin. Profile fields may be null when the user has not been hydrated yet.",
      "parameters": {
        "type": "params",
        "required": ["spaceId"],
        "properties": {
          "spaceId": { "type": "string" }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["members", "externalAdmins"],
          "properties": {
            "members": {
              "type": "array",
              "items": { "type": "ref", "ref": "#member" }
            },
            "externalAdmins": {
              "type": "array",
              "items": { "type": "ref", "ref": "#externalAdmin" }
            }
          }
        }
      }
    },
    "member": {
      "type": "object",
      "required": ["did", "handle", "name", "avatar", "isAdmin", "roleIds"],
      "properties": {
        "did": { "type": "string", "format": "did" },
        "handle": { "type": "string", "format": "handle" },
        "name": { "type": "string" },
        "avatar": { "type": "string" },
        "isAdmin": { "type": "boolean" },
        "roleIds": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "externalAdmin": {
      "type": "object",
      "required": ["did", "handle", "name", "avatar"],
      "properties": {
        "did": { "type": "string", "format": "did" },
        "handle": { "type": "string", "format": "handle" },
        "name": { "type": "string" },
        "avatar": { "type": "string" }
      }
    }
  }
}
