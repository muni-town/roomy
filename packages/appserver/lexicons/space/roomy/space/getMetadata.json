{
  "lexicon": 1,
  "id": "space.roomy.space.getMetadata",
  "defs": {
    "main": {
      "type": "query",
      "description": "Returns space metadata + the complete sidebar tree filtered by the caller's read access. Channels the caller cannot read are omitted from each category and from `orphans`. Caller must be a member or admin of the space. Stage-1: per-channel unreadCount/lastRead are 0/null.",
      "parameters": {
        "type": "params",
        "required": ["spaceId"],
        "properties": {
          "spaceId": { "type": "string" }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "ref",
          "ref": "#metadata"
        }
      }
    },
    "metadata": {
      "type": "object",
      "required": [
        "name",
        "avatar",
        "description",
        "joinPolicy",
        "isMember",
        "isAdmin",
        "sidebar"
      ],
      "properties": {
        "name": { "type": "string" },
        "avatar": { "type": "string" },
        "description": { "type": "string" },
        "joinPolicy": { "type": "ref", "ref": "#joinPolicy" },
        "isMember": { "type": "boolean" },
        "isAdmin": { "type": "boolean" },
        "sidebar": { "type": "ref", "ref": "#sidebar" }
      }
    },
    "joinPolicy": {
      "type": "object",
      "required": ["allowPublicJoin", "allowMemberInvites"],
      "properties": {
        "allowPublicJoin": { "type": "boolean" },
        "allowMemberInvites": { "type": "boolean" }
      }
    },
    "sidebar": {
      "type": "object",
      "required": ["categories", "orphans"],
      "properties": {
        "categories": {
          "type": "array",
          "items": { "type": "ref", "ref": "#category" }
        },
        "orphans": {
          "type": "array",
          "items": { "type": "ref", "ref": "#channel" }
        }
      }
    },
    "category": {
      "type": "object",
      "required": ["id", "name", "position", "channels"],
      "properties": {
        "id": { "type": "string", "description": "Stable category id; null for legacy v0 categories." },
        "name": { "type": "string" },
        "position": { "type": "integer" },
        "channels": {
          "type": "array",
          "items": { "type": "ref", "ref": "#channel" }
        }
      }
    },
    "channel": {
      "type": "object",
      "required": [
        "id",
        "name",
        "defaultAccess",
        "canRead",
        "canWrite",
        "unreadCount",
        "lastRead"
      ],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "defaultAccess": {
          "type": "string",
          "knownValues": ["readwrite", "read", "none"]
        },
        "canRead": { "type": "boolean" },
        "canWrite": { "type": "boolean" },
        "unreadCount": { "type": "integer" },
        "lastRead": { "type": "string", "format": "datetime" }
      }
    }
  }
}
