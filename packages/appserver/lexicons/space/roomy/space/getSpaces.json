{
  "lexicon": 1,
  "id": "space.roomy.space.getSpaces",
  "defs": {
    "main": {
      "type": "query",
      "description": "Returns all spaces where the caller is currently a member or admin. Membership is the join of the caller's personal-stream intent (joinSpace not followed by leaveSpace) AND the space's own stream state (member or admin edge, not banned). Spaces unreachable due to upstream errors are silently skipped. Stage 1 implementation: unreadCount and roleIds are placeholder 0/[] until unread + roles materialisation lands.",
      "parameters": {
        "type": "params",
        "properties": {}
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["spaces"],
          "properties": {
            "spaces": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "id",
                  "name",
                  "avatar",
                  "description",
                  "unreadCount",
                  "isMember",
                  "isAdmin",
                  "roleIds"
                ],
                "properties": {
                  "id": { "type": "string" },
                  "name": { "type": "string" },
                  "avatar": { "type": "string" },
                  "description": { "type": "string" },
                  "unreadCount": { "type": "integer" },
                  "isMember": { "type": "boolean" },
                  "isAdmin": { "type": "boolean" },
                  "roleIds": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        }
      }
    }
  }
}
