{
  "lexicon": 1,
  "id": "space.roomy.space.getThreads",
  "defs": {
    "main": {
      "type": "query",
      "description": "Returns all threads in a space for the board/index view, filtered by the caller's read access (a thread is hidden when its parent channel is unreadable to the caller). Caller must be a member or admin of the space.",
      "parameters": {
        "type": "params",
        "required": ["spaceId"],
        "properties": {
          "spaceId": { "type": "string" }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["threads"],
          "properties": {
            "threads": {
              "type": "array",
              "items": { "type": "ref", "ref": "#thread" }
            }
          }
        }
      }
    },
    "thread": {
      "type": "object",
      "required": ["id", "name", "channel", "activity"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "channel": { "type": "string", "description": "Canonical parent channel id; null when unresolved." },
        "activity": { "type": "ref", "ref": "#activity" }
      }
    },
    "activity": {
      "type": "object",
      "required": ["latestTimestamp", "latestMembers"],
      "properties": {
        "latestTimestamp": { "type": "string", "format": "datetime" },
        "latestMembers": {
          "type": "array",
          "items": { "type": "ref", "ref": "#activityMember" }
        }
      }
    },
    "activityMember": {
      "type": "object",
      "required": ["did", "name", "avatar"],
      "properties": {
        "did": { "type": "string", "format": "did" },
        "name": { "type": "string" },
        "avatar": { "type": "string" }
      }
    }
  }
}
