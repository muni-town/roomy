{
  "lexicon": 1,
  "id": "space.roomy.admin.connectSpace",
  "defs": {
    "main": {
      "type": "query",
      "description": "Admin-only. Connect (lazily, cached) to a Roomy space stream via the appserver's RoomyServiceClient and return basic info — the service DID we authenticated as, plus the rooms list from the space module — to validate the connection works. Caller must be on the appserver's APPSERVER_ADMIN_DIDS allowlist.",
      "parameters": {
        "type": "params",
        "required": ["did"],
        "properties": {
          "did": {
            "type": "string",
            "description": "Stream DID to connect to."
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["serviceDid", "streamDid", "roomCount", "rooms"],
          "properties": {
            "serviceDid": { "type": "string" },
            "streamDid": { "type": "string" },
            "roomCount": { "type": "integer" },
            "rooms": { "type": "array", "items": { "type": "unknown" } }
          }
        }
      }
    }
  }
}
