{
  "lexicon": 1,
  "id": "space.roomy.admin.materializeSpace",
  "defs": {
    "main": {
      "type": "query",
      "description": "Admin-only. Lazily creates (or returns the cached) SpaceMaterializer for the given stream and returns its current state: the persisted backfill cursor, cumulative apply stats, and whether initial backfill has settled. Pass wait=backfill to delay the response until the initial backfill resolves.",
      "parameters": {
        "type": "params",
        "required": ["did"],
        "properties": {
          "did": {
            "type": "string",
            "description": "Stream DID to materialise."
          },
          "wait": {
            "type": "string",
            "description": "Set to 'backfill' to await initial backfill completion before responding.",
            "knownValues": ["backfill"]
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["streamDid", "cursor", "stats", "backfillSettled"],
          "properties": {
            "streamDid": { "type": "string" },
            "cursor": { "type": "integer" },
            "backfillSettled": { "type": "boolean" },
            "stats": {
              "type": "object",
              "required": [
                "applied",
                "materializerErrors",
                "applyErrors",
                "batches"
              ],
              "properties": {
                "applied": { "type": "integer" },
                "materializerErrors": { "type": "integer" },
                "applyErrors": { "type": "integer" },
                "batches": { "type": "integer" }
              }
            }
          }
        }
      }
    }
  }
}
