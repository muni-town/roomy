# ── Appserver ────────────────────────────────────────────────────────────
# Copy this file to .env and fill in values.
# Defaults shown are for local development.

# HTTP port the Bun server listens on
PORT=8080

# DID of this appserver — must match the did.json served at /.well-known/did.json.
# Used for JWT audience validation and as the DID document subject.
APPSERVER_DID=did:web:api.roomy.space

# Public origin of this appserver — the URL clients use to reach it.
# Served as the serviceEndpoint in the DID document.
# On Railway, use RAILWAY_PUBLIC_DOMAIN for external clients or
# RAILWAY_PRIVATE_DOMAIN for inter-service traffic (avoids egress fees).
APPSERVER_ORIGIN=https://api.roomy.space

# Comma-separated DIDs allowed to call admin XRPC endpoints.
# Fails closed: if unset, all admin requests are rejected.
# Set at least one DID in development.
APPSERVER_ADMIN_DIDS=

# ── Leaf (event stream backend) ──────────────────────────────────────────

# Leaf server URL
LEAF_URL=https://leaf-dev.muni.town

# Leaf server DID. If unset, derived from LEAF_URL as did:web:<hostname>.
LEAF_SERVER_DID=

# Auth token for the Leaf server (required for connecting spaces)
LEAF_UNSAFE_AUTH_TOKEN=

# ── Databases (SQLite) ───────────────────────────────────────────────────

# Path to the materialisation database (derived data, can be wiped + re-backfilled)
APPSERVER_DB_PATH=data/roomy.sqlite

# When to backfill Leaf streams into the materialisation DB:
#   eager (default) — discover + materialise every network stream at boot
#   lazy            — materialise each space on first request instead
# Lazy trades first-request completeness for fast boot; invalidation signals
# fill in the rest once backfill completes.
APPSERVER_BACKFILL_MODE=eager

# Max spaces materialised concurrently during eager startup backfill (default 4).
# Overlaps per-space Leaf subscription + profile fetches; SQLite writes still
# serialize on the single WAL writer. Lower if Leaf or the appview struggles.
# (Lowered from 8→4 after 8 workers wedged Leaf at ~885 streams in prod.)
APPSERVER_BACKFILL_CONCURRENCY=4

# ── Backfill circuit breaker ────────────────────────────────────────────
# When a backfill worker hits this many consecutive failures, it pauses with
# exponential backoff (below) before pulling the NEXT stream. Stops a wedged
# Leaf from being hammered by a 30s-timeout-per-stream churn.
APPSERVER_BACKFILL_FAILURE_THRESHOLD=3
# Base pause (ms) for the first breaker trip; doubles each trip up to the cap.
APPSERVER_BACKFILL_BACKOFF_MS=5000
# Maximum pause (ms) between streams during a sustained outage.
APPSERVER_BACKFILL_BACKOFF_MAX_MS=60000
# Emit a `[startup] progress …` line every N completed spaces (plus the final
# one). Default 50 avoids per-DID log flooding at scale; set 1 for per-DID detail.
APPSERVER_BACKFILL_PROGRESS_EVERY=50
# Timeout (ms) for mat.close() (drain + Leaf unsubscribe) during startup
# backfill. close() isn't SDK-bounded, so a dead Leaf can't strand a worker.
# NOTE: a timed-out close() is NOT cancelled — its Leaf subscription lingers
# in the background and may accumulate transiently under outage + timeout.
APPSERVER_BACKFILL_CLOSE_TIMEOUT_MS=15000
# Connect deadline (ms) for RoomyServiceClient.connectSpace. Bounds streamInfo +
# mod CID/upload/update so a dead Leaf socket can't hang callers (incl. all
# backfill workers + XRPC handlers sharing the cached client).
APPSERVER_CONNECT_TIMEOUT_MS=30000

# ── Logging ─────────────────────────────────────────────────────────────
# Threshold (inclusive): debug < info < warn < error. Default info.
# Set debug to see per-DID backfill detail and embed-sweeper internals.
LOG_LEVEL=info

# Path to the read-state database (appserver-owned, survives materialisation resets)
READSTATE_DB_PATH=data/roomy-readstate.sqlite

# Path to the debug event store (optional, for forensics).
# When set, every raw event and materialization result is logged to this
# separate DB. Query with sqlite3 CLI. Leave unset in production.
APPSERVER_DEBUG_DB_PATH=data/debug.sqlite

# ── Personal stream resolution ───────────────────────────────────────────

# ATProto collection NSID for personal-stream records on user PDS repos
APPSERVER_PERSONAL_STREAM_NSID=space.roomy.space.personal.next

# Schema version rkey for personal-stream records
APPSERVER_PERSONAL_STREAM_SCHEMA_VERSION=4

# ── Identity resolution ──────────────────────────────────────────────────

# PLC directory URL for DID resolution
PLC_DIRECTORY_URL=https://plc.directory

# ── CORS ─────────────────────────────────────────────────────────────────

# Allowed origin for CORS headers. Set to your app URL in production.
# Use "*" for development (allows all origins).
CORS_ORIGIN=*

# —— EMBED SERVICE ————————————————————————————————————————————————————
# Embed (link-card) metadata service. POST a URL, returns OpenGraph/oEmbed.
EMBED_SERVICE_URL=https://embed.internal.weird.one
# Hard timeout (ms) for a single embed-service request. Without it a hung
# service leaves links pending and amplifies re-fetches.
EMBED_FETCH_TIMEOUT_MS=10000
# Max concurrent outbound embed-service fetches per sweep batch. Bounded so a
# large pending batch can't flood the service while still draining quickly.
EMBED_SWEEPER_CONCURRENCY=8
# Cap (ms) for transient-failure retry backoff (schedule: 1m→5m→30m→2h→cap).
EMBED_RETRY_CAP_MS=21600000
