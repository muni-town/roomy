# ── Appserver ────────────────────────────────────────────────────────────
# Copy this file to .env and fill in values.
# Defaults shown are for local development.

# HTTP port the Bun server listens on
PORT=8080

# DID of this appserver — must match the did.json served at /.well-known/did.json.
# Used for JWT audience validation and as the DID document subject.
APPSERVER_DID=did:web:api.roomy.space

# Public origin of this appserver — the URL clients use to reach it.
# Served as the serviceEndpoint in the DID document.
# On Railway, use RAILWAY_PUBLIC_DOMAIN for external clients or
# RAILWAY_PRIVATE_DOMAIN for inter-service traffic (avoids egress fees).
APPSERVER_ORIGIN=https://api.roomy.space

# Comma-separated DIDs allowed to call admin XRPC endpoints.
# Fails closed: if unset, all admin requests are rejected.
# Set at least one DID in development.
APPSERVER_ADMIN_DIDS=

# ── Leaf (event stream backend) ──────────────────────────────────────────

# Leaf server URL
LEAF_URL=https://leaf-dev.muni.town

# Leaf server DID. If unset, derived from LEAF_URL as did:web:<hostname>.
LEAF_SERVER_DID=

# Auth token for the Leaf server (required for connecting spaces)
LEAF_UNSAFE_AUTH_TOKEN=

# ── Databases (SQLite) ───────────────────────────────────────────────────

# Path to the materialisation database (derived data, can be wiped + re-backfilled)
APPSERVER_DB_PATH=data/roomy.sqlite

# Path to the read-state database (appserver-owned, survives materialisation resets)
READSTATE_DB_PATH=data/roomy-readstate.sqlite

# ── Personal stream resolution ───────────────────────────────────────────

# ATProto collection NSID for personal-stream records on user PDS repos
APPSERVER_PERSONAL_STREAM_NSID=space.roomy.space.personal.next

# Schema version rkey for personal-stream records
APPSERVER_PERSONAL_STREAM_SCHEMA_VERSION=4

# ── Identity resolution ──────────────────────────────────────────────────

# PLC directory URL for DID resolution
PLC_DIRECTORY_URL=https://plc.directory

# ── CORS ─────────────────────────────────────────────────────────────────

# Allowed origin for CORS headers. Set to your app URL in production.
# Use "*" for development (allows all origins).
CORS_ORIGIN=*
