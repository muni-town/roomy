{
	"name": "@roomy/discord-bridge",
	"version": "0.0.0",
	"private": true,
	"license": "PolyForm-Noncommercial-1.0.0",
	"description": "Unidirectional Discord-to-Roomy bridge (Bun runtime)",
	"type": "module",
	"engines": {
		"bun": ">=1.1.0"
	},
	"scripts": {
		"dev": "bun run --watch src/index.ts",
		"start": "bun run src/index.ts",
		"build": "bun build src/index.ts --target=bun --outdir=dist",
		"test": "bun test",
		"format": "pnpx @biomejs/biome format --write",
		"lint": "pnpx @biomejs/biome lint --diagnostic-level=hint",
		"fix": "pnpx @biomejs/biome check --fix",
		"typecheck": "tsc --noEmit",
		"generate:fake-data": "bun run src/scripts/generate-fake-data.ts",
		"generate:fake-data:quick": "bun run src/scripts/generate-fake-data.ts --quick",
		"generate:fake-data:large": "bun run src/scripts/generate-fake-data.ts --channels 15 --threads 250"
	},
	"dependencies": {
		"@atcute/cbor": "^2.2.8",
		"@atproto/api": "^0.14.22",
		"@discordeno/bot": "^21.0.0",
		"@roomy-space/sdk": "workspace:*",
		"arktype": "^2.1.29",
		"dd-cache-proxy": "^2.7.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.0",
		"@faker-js/faker": "^10.4.0",
		"@repo/tsconfig": "workspace:*",
		"@types/bun": "latest",
		"biome-plugin-no-type-assertion": "^1.1.1",
		"typescript": "^5.8.3"
	}
}
