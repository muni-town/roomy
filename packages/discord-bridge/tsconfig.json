{
	"extends": "@repo/tsconfig/base.json",
	"compilerOptions": {
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"types": ["bun"],
		"customConditions": ["development"],
		"outDir": "dist",
		"rootDir": "src",
		"noEmit": true
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist"]
}
